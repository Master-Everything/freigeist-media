{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "freigeist-kongress-mcp",
      "version": "0.1.0",
      "title": "Freigeist Kongress MCP"
    },
    "tools": [
      {
        "name": "list_posts",
        "title": "List published posts",
        "description": "List published articles from the Freigeist Kongress site. Returns id, title, subtitle, category, published_at, and reading_time. Filter by category slug or full-text query.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "description": "Optional search text matched against title/subtitle/content.",
              "type": "string"
            },
            "category_slug": {
              "description": "Optional category slug to filter by.",
              "type": "string"
            },
            "limit": {
              "default": 20,
              "description": "Max results to return (1-50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_post",
        "title": "Get post by id or slug",
        "description": "Fetch the full content of a single published article by its id (uuid) or slug. Returns title, subtitle, body content, category, and publish date.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id_or_slug": {
              "type": "string",
              "minLength": 1,
              "description": "Post uuid or slug."
            }
          },
          "required": [
            "id_or_slug"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_categories",
        "title": "List categories",
        "description": "List all article categories with their slug and name.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
