# Lokale Entwicklung mit Supabase CLI
# Kopiere diese Datei zu .env.local und trage die Werte vom "supabase start" Output ein.
# Diese Datei wird NICHT ins Git committed (.gitignore schließt .env* aus).

# Ausgabe von "supabase start":
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=<anon key vom "supabase start" Output>
VITE_SUPABASE_PROJECT_ID=local

# Optional: Basis-URL für Bild-Dateien (Standard: $VITE_SUPABASE_URL/storage/v1/object/public/)
# Für Self-Hosting z.B.: VITE_IMAGE_BASE_URL=http://localhost:8000/
# VITE_IMAGE_BASE_URL=
